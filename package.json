{
  "name": "behalf-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the @behalf-js/* packages — never itself published.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "typecheck:tools": "tsc --noEmit --project tools/tsconfig.json",
    "typecheck:docs-examples": "tsc --noEmit --project docs/examples/tsconfig.json",
    "typecheck:examples": "tsc --noEmit --project examples/simple-chat/tsconfig.json && tsc --noEmit --project examples/multi-step-agent/tsconfig.json",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"docs/**/*.md\" \"README.md\" \"CONTRIBUTING.md\"",
    "lint:links": "remark --quiet --frail docs README.md CONTRIBUTING.md",
    "lint:docs": "npm run lint:md && npm run lint:links",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run typecheck && npm run typecheck:tools && npm run lint && npm run lint:docs",
    "verify": "npm run build && npm run check && npm run typecheck:docs-examples && npm run typecheck:examples && npm test",
    "fix": "npm run format && npm run lint -- --fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.5",
    "prettier-plugin-sentences-per-line": "^0.2.4",
    "remark-cli": "^12.0.1",
    "remark-validate-links": "^13.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
